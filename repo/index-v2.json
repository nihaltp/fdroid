                "name": "/com.nihaltp.aftersleep/en-US/phoneScreenshots/1.jpg",
                "sha256": "fa068f7d9a6555dcb3a9a106a4ed4069fbdec523d45d60c4349a07e0f75964a4",
                "size": 78400
              },
              {
